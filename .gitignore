# =============================================================================
# AuraGate — Git Ignore Rules
# =============================================================================
# Purpose:
#   Prevent secrets, build artifacts, and OS-specific files from being
#   committed to version control. Organized by category.
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets & Environment
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local

# -----------------------------------------------------------------------------
# Node.js & Package Managers
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# -----------------------------------------------------------------------------
# Next.js
# -----------------------------------------------------------------------------
.next/
out/

# -----------------------------------------------------------------------------
# Build & Compiled Output
# -----------------------------------------------------------------------------
dist/
build/
*.tsbuildinfo

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
*.js.map
*.d.ts.map

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
coverage/
.nyc_output/

# -----------------------------------------------------------------------------
# Docker (generated files, not the compose manifest itself)
# -----------------------------------------------------------------------------
docker-compose.override.yml

# -----------------------------------------------------------------------------
# IDE & Editors
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# -----------------------------------------------------------------------------
# OS Files
# -----------------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini

testPROJECT_KNOWLEDGE_TRANSFER.md
AGENTS.md
CLAUDE.md
Makefile
