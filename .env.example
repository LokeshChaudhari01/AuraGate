# =============================================================================
# AuraGate — Environment Configuration Template
# =============================================================================
# Purpose:
#   Template for all environment variables consumed by docker-compose.yml
#   and (in future phases) the Next.js application.
#
# Setup:
#   cp .env.example .env
#   Then edit .env with your desired values.
#
# IMPORTANT: Never commit the .env file to version control.
#            This .env.example file IS safe to commit.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL Configuration
# -----------------------------------------------------------------------------
# These variables are consumed by the official postgres Docker image on
# first initialization. Changing them after the volume is created has no
# effect — you must `make destroy` and re-initialize.
# -----------------------------------------------------------------------------
POSTGRES_USER=auragate_user
POSTGRES_PASSWORD=auragate_pg_dev_password
POSTGRES_DB=auragate
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
# REDIS_PASSWORD is passed to `--requirepass` in the Redis server command
# and used by all clients (rate limiter, cache, BullMQ) to authenticate.
# -----------------------------------------------------------------------------
REDIS_PASSWORD=auragate_redis_dev_password
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Database Connection (Drizzle ORM)
# -----------------------------------------------------------------------------
# Fully resolved connection string for Drizzle ORM and node-postgres.
# Must match the POSTGRES_* values above. Drizzle does not support
# variable interpolation, so this must be a literal string.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://auragate_user:auragate_pg_dev_password@localhost:5432/auragate

# -----------------------------------------------------------------------------
# Redis Connection (ioredis)
# -----------------------------------------------------------------------------
# Full connection string for the ioredis client. Used by rate limiter,
# prompt cache, key cache, and BullMQ (Phase 5).
# Format: redis://:<password>@<host>:<port>
# -----------------------------------------------------------------------------
REDIS_URL=redis://:auragate_redis_dev_password@localhost:6379

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# Sliding window rate limiter configuration (per API key).
# RATE_LIMIT_MAX: Maximum requests allowed per window.
# RATE_LIMIT_WINDOW_MS: Window size in milliseconds.
# Default: 100 requests per 60 seconds.
# -----------------------------------------------------------------------------
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# Prompt Cache
# -----------------------------------------------------------------------------
# Cache-aside TTL for LLM prompt responses.
# PROMPT_CACHE_TTL_SECONDS: Base TTL (jitter added automatically).
# Default: 3600 seconds (1 hour).
# -----------------------------------------------------------------------------
PROMPT_CACHE_TTL_SECONDS=3600

# -----------------------------------------------------------------------------
# LLM Provider — Gemini (Phase 4)
# -----------------------------------------------------------------------------
# API key for Google Gemini. Required for the proxy to function.
# Get one from: https://aistudio.google.com/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------------------------
# Cost Routing (Phase 4)
# -----------------------------------------------------------------------------
# COST_ROUTING_THRESHOLD: Estimated token count threshold. Below → cheap model.
# COST_ROUTING_CHEAP_MODEL: Model for small/simple prompts (fast, cheap).
# COST_ROUTING_HEAVY_MODEL: Model for complex/large prompts (powerful).
# -----------------------------------------------------------------------------
COST_ROUTING_THRESHOLD=500
COST_ROUTING_CHEAP_MODEL=gemini-2.0-flash
COST_ROUTING_HEAVY_MODEL=gemini-1.5-pro

# -----------------------------------------------------------------------------
# Proxy Timeouts (Phase 4)
# -----------------------------------------------------------------------------
# All timeout values come from env — zero hardcoded (AD-12).
# PROXY_TIMEOUT_MS: Primary provider timeout before failover.
# PROXY_FALLBACK_TIMEOUT_MS: Fallback provider timeout before giving up.
# -----------------------------------------------------------------------------
PROXY_TIMEOUT_MS=4000
PROXY_FALLBACK_TIMEOUT_MS=8000
